# ──────────────────────────────────────────────
# API Configuration (copy sang .env rồi điền giá trị)
# ──────────────────────────────────────────────
# Để trống = dùng mock data local (không cần server)
# Điền URL thật = gọi API thật, ví dụ:
#   VITE_API_BASE_URL=https://api.tienthu.com.vn/v1
VITE_API_BASE_URL=

# Request timeout (ms)
VITE_API_TIMEOUT=15000
